<!doctype html>
<html lang="en">
{{> head}}
<body>
  {{!-- Staff sign-in pill (→ the Bench). Styled INLINE on purpose: the HTML is
        fresh on every deploy, whereas css/main.css can be CDN-cached, so inline
        styling can never render stale/unstyled. var() fallbacks keep it safe. --}}
  <style>
    .cs__signin{position:absolute;z-index:3;top:clamp(1.4rem,.8rem + 1.6vw,2.4rem);right:clamp(1.6rem,.8rem + 2vw,3rem);
      text-decoration:none;line-height:1;white-space:nowrap;
      border:0!important;background:none!important;padding:0!important;border-radius:0!important;-webkit-backdrop-filter:none!important;backdrop-filter:none!important;box-shadow:none!important;
      font-family:'Cinzel',Georgia,serif;text-transform:uppercase;font-size:var(--fs-sm,.92rem);letter-spacing:.14em;
      color:rgb(var(--gold-500,201 160 78));transition:color .25s}
    .cs__signin:hover,.cs__signin:focus-visible{color:rgb(var(--gold-300,243 221 164));background:none!important;border-color:transparent!important}
    @media(max-width:34rem){.cs__signin{top:10px;right:12px;font-size:.72rem}}
  </style>

  {{> sigil-defs}}
  {{> site-frame}}

  <main class="cs">
    <canvas class="ember-canvas" data-embers data-density="1.4" aria-hidden="true"></canvas>

    <a class="cs__signin" href="https://bench.ninelives.repair/login">Sign in</a>

    <nav class="cs__topbar" aria-label="What we do">
      {{#each site.services}}<span class="cs__topbar-item">{{this}}</span>{{#unless @last}}<span class="cs__topbar-dot" aria-hidden="true">·</span>{{/unless}}{{/each}}
    </nav>

    <div class="cs__inner">
      <div class="cs__content">
        <span class="cs__seal"><svg class="sigil-svg cs__seal-svg"><use href="#sigil-node" /></svg></span>
        <h1 class="cs__title font-ritual text-bone-100">{{site.brand}}</h1>
        <p class="cs__subtitle font-reverie italic text-gold-400">{{site.hero.subtitle}}</p>
        <span class="cs__rule" aria-hidden="true"></span>
        <p class="cs__lede">{{site.hero.lede}}</p>
      </div>

      <span class="cs__divide" aria-hidden="true"></span>

      <aside class="cs__rite">
        <p class="cs__rite-kicker">{{site.hero.rite.kicker}}</p>
        <h2 class="cs__rite-title font-ritual text-bone-100">{{site.hero.rite.title}}</h2>
        <p class="cs__rite-lede">{{site.hero.rite.lede}}</p>
        <form class="cs__notify" id="cs-notify" novalidate>
          <input class="input" id="cs-email" name="email" type="email" required placeholder="your@email.com" aria-label="Email address" autocomplete="email" />
          <button class="btn btn-solid" type="submit"><i class="ph ph-bell"></i> Notify me</button>
        </form>
        <p class="cs__note text-smoke" id="cs-status" role="status" aria-live="polite"><i class="ph-fill ph-paw-print cs__paw"></i> {{site.hero.rite.note}}</p>
      </aside>
    </div>

    <footer class="cs__footer footer-mark">
      <span class="footer-mark__domain">{{site.footer.domain}}</span>
      <span class="footer-mark__numeral">{{site.footer.numeral}}</span>
      <span class="footer-mark__est">{{site.footer.est}}</span>
    </footer>
  </main>

  {{!-- Coming-soon signup: POSTs to the Bench host (which holds Resend + the
        themed thank-you email). Inline for the same fresh-on-every-deploy reason
        as the sign-in pill above. --}}
  <script>
  (function () {
    var ENDPOINT = 'https://bench.ninelives.repair/api/notify';
    var form = document.getElementById('cs-notify');
    if (!form) return;
    var email = document.getElementById('cs-email');
    var status = document.getElementById('cs-status');
    var btn = form.querySelector('button[type=submit]');
    var EMAIL_RE = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;
    function show(msg, kind) {
      status.textContent = msg;
      status.style.color = kind === 'err' ? 'rgb(var(--danger, 200 80 70))'
        : kind === 'ok' ? 'rgb(var(--gold-300, 243 221 164))'
        : 'rgb(var(--smoke, 126 118 137))';
    }
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var val = (email.value || '').trim();
      if (!EMAIL_RE.test(val)) { show('Please enter a valid email address.', 'err'); email.focus(); return; }
      btn.disabled = true; show('Summoning…', '');
      fetch(ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'email=' + encodeURIComponent(val),
      })
        .then(function (r) { return r.json().catch(function () { return { ok: r.ok }; }); })
        .then(function (d) {
          if (d && d.ok) { form.style.display = 'none'; show("You're on the list — check your inbox.", 'ok'); }
          else { btn.disabled = false; show((d && d.error) || 'Something went wrong — please try again.', 'err'); }
        })
        .catch(function () { btn.disabled = false; show('Network error — please try again.', 'err'); });
    });
  })();
  </script>
  <script src="js/embers.js"></script>
  <script type="module" src="js/index.js"></script>
</body>
</html>
